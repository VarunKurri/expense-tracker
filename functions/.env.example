# Plaid configuration for Trackr Cloud Functions.
# Copy non-secret values into functions/.env, and put the secrets in
# functions/.secret.local (for the emulator) or set them with the Firebase CLI
# (`firebase functions:secrets:set NAME`) for deployment.

# --- Non-secret params (safe to keep in functions/.env) ---

# Which Plaid environment to talk to: sandbox | production.
# Defaults to sandbox. Flip to production (with the Trial plan's 10-Item limit)
# without any code change.
PLAID_ENV=sandbox

# Public URL Plaid POSTs to for ongoing transaction sync. Leave blank until the
# webhook function is deployed; then set it to the deployed function URL, e.g.
# https://us-central1-expense-tracker-ai-5e35a.cloudfunctions.net/plaidWebhook
PLAID_WEBHOOK_URL=

# --- Secrets (do NOT commit; use .secret.local or `firebase functions:secrets:set`) ---

# PLAID_CLIENT_ID=your_plaid_client_id
# PLAID_SECRET=your_plaid_sandbox_or_production_secret

# Base64-encoded 32-byte key used to AES-256-GCM encrypt stored Plaid access
# tokens. Needed starting at the token-exchange milestone (not used yet).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# TOKEN_ENC_KEY=
