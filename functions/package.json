{
  "name": "functions",
  "description": "Cloud Functions for Trackr (Plaid integration)",
  "private": true,
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.1.1",
    "jose": "^6.2.3",
    "plaid": "^29.0.0"
  },
  "devDependencies": {
    "typescript": "~5.9.2"
  }
}
